{
  "enabled": true,
  "mode": "rewrite",
  "profile": "balanced",
  "lambda_constraint": 0.5,
  "threshold_warn": 0.55,
  "threshold_block": 0.82,
  "threshold_rewrite": 0.68,
  "max_regenerations": 2,
  "tag_prefix": "[CCI-GUARD]",
  "append_report": true,
  "write_jsonl": true,
  "strict_prefix_enabled": false,
  "rewrite_template": "I can help with this safely and clearly. Here is a lower-stress reformulation that preserves useful intent while avoiding unsafe or unstable content:\n\n{content}",
  "w_instability": 1.0,
  "w_activity": 0.7,
  "w_imbalance": 0.5,
  "w_coherence": 0.8,
  "w_consistency": 0.8,
  "w_correlation": 0.5,
  "w_integrity": 0.9,
  "instability_keywords": [
    "ignore previous",
    "ignore all previous",
    "disregard instructions",
    "override",
    "bypass",
    "jailbreak",
    "system prompt",
    "developer message",
    "hidden policy",
    "reveal prompt",
    "do not follow safety",
    "unfiltered",
    "break character",
    "act as",
    "simulate malware",
    "steal",
    "exploit"
  ],
  "conflict_keywords": [
    "but also",
    "however ignore",
    "at the same time",
    "contradict",
    "must and must not",
    "without restrictions",
    "no matter what"
  ],
  "coherence_markers": [
    "therefore",
    "because",
    "however",
    "first",
    "second",
    "finally",
    "in summary",
    "for example"
  ],
  "integrity_keywords": [
    "system prompt",
    "developer prompt",
    "hidden instructions",
    "policy leak",
    "prompt injection",
    "chain of thought",
    "cot",
    "internal reasoning"
  ],
  "allowlist_keywords": [
    "fiction",
    "analysis",
    "history",
    "safety",
    "critique",
    "compare",
    "research"
  ],
  "batch_default_repeats": 3,
  "batch_default_modes": [
    "balanced",
    "strict"
  ],
  "batch_log_filename": "batch_results_v3.jsonl"
}